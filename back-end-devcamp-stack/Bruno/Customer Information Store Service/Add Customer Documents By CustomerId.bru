meta {
  name: Add Customer Documents By CustomerId
  type: http
  seq: 7
}

post {
  url: {{baseurl}}:{{port_customer}}/v1/customer/:customerId/documents
  body: json
  auth: inherit
}

params:path {
  customerId: 1
}

body:json {
  {
      "document": "some-base64-content",
      "name": "some-name-or-description"
  }
}

settings {
  encodeUrl: true
}
